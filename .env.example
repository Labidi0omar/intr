# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Sentry DSN — when unset, Sentry.init is skipped and all calls no-op (see CLAUDE.md).
# Format: https://<key>@<host>/<project_id>
EXPO_PUBLIC_SENTRY_DSN=
# real numeric Meta App ID; iOS Stories share is a no-op without it
EXPO_PUBLIC_FACEBOOK_APP_ID=
