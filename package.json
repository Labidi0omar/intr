    "expo-build-properties": "^56.0.15",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.15",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.11",
