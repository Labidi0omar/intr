    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
